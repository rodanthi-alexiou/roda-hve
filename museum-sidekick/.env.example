# ----------------------------------------------------------------------------
# Museum Sidekick - local environment
# Copy to .env and fill in values. Never commit .env.
# ----------------------------------------------------------------------------

# --- Azure OpenAI (GPT-4o with vision) ---
# Endpoint of your Azure OpenAI / Foundry resource.
AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com"
# The deployment name of your gpt-4o model (must be a vision-capable gpt-4o).
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
# API version.
AZURE_OPENAI_API_VERSION="2024-10-21"
# For local dev you can use a key. In Azure, leave this empty and the app uses
# Managed Identity (DefaultAzureCredential) instead.
AZURE_OPENAI_API_KEY=""

# --- API server ---
PORT="3000"

# --- Observability (Azure Application Insights) ---
# Leave empty locally: telemetry falls back to structured JSON logs on stdout.
# In Azure this is set automatically from the Terraform-provisioned resource.
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# --- Frontend ---
# Base URL the frontend uses to reach the API.
VITE_API_BASE_URL="http://localhost:3000"
